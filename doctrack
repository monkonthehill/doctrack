#!/bin/bash

# Check argument
if [ -z "$1" ]; then
    echo "Usage: doctrack <folder>"
    exit 1
fi

TARGET_DIR=$1

# Check if folder exists
if [ ! -d "$TARGET_DIR" ]; then
    echo "❌ Folder not found: $TARGET_DIR"
    exit 1
fi

echo "🚀 Running DocTrack on $TARGET_DIR"

# Run your compiled C++ binary
# (Assumes your binary is named 'doctrack_bin')
./doctrack_bin "$TARGET_DIR"

# Convert to HTML
if command -v pandoc &> /dev/null; then
    pandoc doc.md -s -o report.html
    echo "🌐 HTML report generated: report.html"
else
    echo "⚠️ Pandoc not installed, skipping HTML conversion"
fi

echo "✅ Done"
